# Example environment variables
# Copy this to .env and fill in your values

# Google Maps (required for recommend_meal tool)
# Enable Geocoding API and Places API (Legacy) in Google Cloud Console.
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Optional: API keys for other external services
# MY_API_KEY=your-api-key-here

# Server configuration
PORT=3000
