{
  "mcpServers": {
    "meal-planner": {
      "type": "stdio",
      "command": "npx",
      "args": ["tsx", "src/stdio.ts"]
    },
    "meal-planner-compiled": {
      "type": "stdio",
      "command": "node",
      "args": ["dist/stdio.js"]
    },
    "meal-planner-http": {
      "type": "http",
      "url": "http://localhost:3000/mcp"
    }
  }
}
